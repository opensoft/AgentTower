# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Generated code (build_runner: freezed + json_serializable). Regenerated
# locally via `dart run build_runner build --delete-conflicting-outputs`;
# CI runs the same step before analyze/test, so the .freezed.dart and
# .g.dart files must NOT be committed.
**/*.freezed.dart
**/*.g.dart

# Flutter-generated localization output (flutter gen-l10n, driven by
# l10n.yaml). Source of truth lives in assets/l10n/*.arb.
lib/core/l10n/app_localizations*.dart

# Per-platform plugin registrants generated on every `flutter pub get`.
linux/flutter/generated_plugin_registrant.*
linux/flutter/generated_plugins.cmake
macos/Flutter/GeneratedPluginRegistrant.swift
windows/flutter/generated_plugin_registrant.*
windows/flutter/generated_plugins.cmake

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
